# .env.example — 環境變數範例文件

# Database (SQLite for local dev, PostgreSQL for production)
# 本地開發：SQLite
DATABASE_URL=sqlite:///./database/qubo.db

# 正式環境範例（需要自行配置）：
# DATABASE_URL=postgresql://user:password@localhost:5432/qubo_db

# CORS - 前端允許來源
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Worker - 背景任務執行器
WORKER_ENABLED=true
WORKER_CHECK_INTERVAL=2  # 秒，掃描待處理任務的頻率
